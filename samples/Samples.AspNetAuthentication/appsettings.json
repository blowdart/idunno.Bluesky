{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Samples.AspNetAuthentication": "Warning"
        }
    },

    "Console": {
        "IncludeScopes": true,
        "FormatterName": "Simple",
        "FormatterOptions": {
            "SingleLine": true,
            "IncludeScopes": true,
            "TimestampFormat": "HH:mm:ss ",
            "UseUtcTimestamp": true
        }
    },

    "BlueskyAgent": {
        "EnableBackgroundTokenRefresh": false,

        "OAuthOptions": {
            "ClientId": "https://example.idunno.blue/",
            "ReturnUri": "http://example.idunno.blue/Authentication/Callback",
            "Scopes": [ "atproto", "transition:generic" ]
        }
    },

    "AllowedHosts": "localhost;127.0.0.1"
}
